generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UsuarioPerfil {
  ADMIN
  VENDEDOR
}

model Usuario {
  id        Int           @id @default(autoincrement())
  nome      String
  email     String        @unique
  senha     String
  perfil    UsuarioPerfil @default(VENDEDOR)
  createdAt DateTime      @default(now())
  vendas    Venda[]

  @@map("usuarios")
}

model Cliente {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  cidade       String
  estado       String
  pais         String
  dataCadastro DateTime @default(now())
  vendas       Venda[]

  @@map("clientes")
}

model Categoria {
  id       Int       @id @default(autoincrement())
  nome     String
  produtos Produto[]

  @@map("categorias")
}

model Produto {
  id          Int         @id @default(autoincrement())
  categoriaId Int?
  categoria   Categoria?  @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  marca       String
  nome        String
  cor         String
  genero      String
  tamanho     String
  preco       Float
  estoque     Int         @default(0)
  createdAt   DateTime    @default(now())
  itens       VendaItem[]

  @@map("produtos")
}

model Venda {
  id        Int         @id @default(autoincrement())
  usuarioId Int?
  usuario   Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  clienteId Int
  cliente   Cliente     @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  total     Float
  status    VendaStatus @default(ATIVO)
  data      DateTime    @default(now())
  itens     VendaItem[]

  @@map("vendas")
}

model VendaItem {
  id            Int     @id @default(autoincrement())
  vendaId       Int
  venda         Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produtoId     Int
  produto       Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  quantidade    Int
  precoUnitario Float
  subtotal      Float

  @@map("venda_itens")
}

enum VendaStatus {
  ATIVO
  CANCELADO
}
