generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UsuarioPerfil {
  GESTOR
  VENDEDOR
}

enum VendaStatus {
  CONCLUIDA
  CANCELADO
  PENDENTE_PAGAMENTO
}

model Usuario {
  id        BigInt           @id @default(autoincrement())
  nome      String        @db.VarChar(100)
  email     String        @unique @db.VarChar(150)
  senha     String        @db.VarChar(255)
  perfil    UsuarioPerfil @default(VENDEDOR)
  createdAt DateTime      @default(now())
  vendas    Venda[]

  @@map("usuarios")
}

model Cliente {
  id           BigInt      @id @default(autoincrement())
  nome         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  cidade       String   @db.VarChar(100)
  estado       String   @db.VarChar(2)
  pais         String   @db.VarChar(60)
  dataCadastro DateTime @default(now())
  vendas       Venda[]

  @@map("clientes")
}

model Categoria {
  id       BigInt       @id @default(autoincrement())
  nome     String    @db.VarChar(60)
  produtos Produto[]

  @@map("categorias")
}

model Produto {
  id          BigInt        @id @default(autoincrement())
  categoriaId BigInt?
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  marca       String     @db.VarChar(100)
  nome        String     @db.VarChar(150)
  cor         String     @db.VarChar(50)
  genero      String     @db.VarChar(20)
  tamanho     String     @db.VarChar(10)
  preco       Float
  estoque     Int        @default(0)
  createdAt   DateTime   @default(now())
  itens       VendaItem[]

  @@map("produtos")
}

model Venda {
  id        BigInt         @id @default(autoincrement())
  usuarioId BigInt?
  usuario   Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  clienteId BigInt
  cliente   Cliente     @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  total     Float
  status    VendaStatus @default(PENDENTE_PAGAMENTO)
  dataVenda    DateTime    @default(now())
  itens     VendaItem[]

  @@map("vendas")
}

model VendaItem {
  id            BigInt     @id @default(autoincrement())
  vendaId       BigInt
  venda         Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produtoId     BigInt
  produto       Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  quantidade    Int
  precoUnitario Float
  subtotal      Float

  @@map("venda_itens")
}


